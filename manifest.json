{
  "manifest_version": 3,
  "name": "Gemini 批量生图插件",
  "version": "2.1",
  "description": "自动执行 Gemini 作图提示词队列，附带侧边栏、进度条、计时器和日志",
  "icons": {
    "16": "icon128.png",
    "48": "icon128.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "切换侧边栏",
    "default_icon": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "downloads"
  ],
  "host_permissions": [
    "https://*.google.com/*",
    "https://*.googleusercontent.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://grok.com/*"
      ],
      "css": [
        "sidebar.css"
      ],
      "js": [
        "jszip.min.js",
        "prompts.js",
        "automation.js",
        "sidebar.js"
      ]
    }
  ]
}